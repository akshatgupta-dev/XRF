/control/verbose 2
/run/verbose 1
/event/verbose 0
/tracking/verbose 0
/det/setWorldMaterial G4_WATER
/run/initialize
/vis/open OGL
/vis/drawVolume

# hide world if still visible
/vis/geometry/set/visibility World 0 true

# make objects easier to inspect
/vis/viewer/set/style wireframe
/vis/scene/add/axes 0 0 0 30 mm
/vis/viewer/set/autoRefresh true
/vis/viewer/set/viewpointThetaPhi 70 30
/vis/viewer/zoom 20

# trajectories
/tracking/storeTrajectory 1
/vis/scene/add/trajectories smooth
/vis/scene/endOfEventAction accumulate 10