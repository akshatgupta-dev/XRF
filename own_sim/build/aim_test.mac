/physics_lists/em/ReplacePhysics G4EmLivermorePhysics
/xrf/setMaterial G4_Fe
/xrf/setBeamEnergy 20 keV
/xrf/setSourceDistance 50 mm
/xrf/setDetectorDistance 20 mm
/xrf/setIncidentAngle 45 deg
/xrf/setNominalTakeoff -45 deg
/xrf/setSpread 10 deg
/xrf/setStep 1 deg
/xrf/clearShieldLayers
/xrf/setShieldEnabled false
/run/initialize
/gps/particle gamma
/gps/energy 50 keV
/gps/number 1000
/run/beamOn 20
