/control/verbose 1
/run/verbose 1
/xrf/setMaterial G4_Cu
/xrf/setBeamEnergy 20 keV
/xrf/setIncidentAngle 50 deg
/xrf/setSourceDistance 60 mm
/xrf/setDetectorDistance 30 mm
/xrf/setNominalTakeoff 47 deg
/xrf/setSpread 4 deg
/xrf/setStep 2 deg
/xrf/setTotalEvents 100000
/xrf/setChunkSize 1000
/xrf/run
