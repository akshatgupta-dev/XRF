/control/verbose 1
/run/verbose 1
/xrf/setMaterial G4_Fe
/xrf/setBeamEnergy 15 keV
/xrf/setIncidentAngle 45 deg
/xrf/setSourceDistance 50 mm
/xrf/setDetectorDistance 20 mm
/xrf/setNominalTakeoff 45 deg
/xrf/setSpread 4 deg
/xrf/setStep 2 deg
/xrf/setTotalEvents 10000
/xrf/setChunkSize 1000
/xrf/run
